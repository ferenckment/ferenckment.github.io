---
import Base from '../../../layouts/Base.astro';

const helpers = [
  'Dr. Horváth Gabriella',
  'Madár Emőke',
  'Dr. Ungár Júlia',
  'Horváth László',
  'Kalmár Ágnes',
  'Kalmár László',
  'Kalmár Magdolna',
  'Kalmár Márta',
  'Karsai Viktória',
  'Kment Ábel',
  'Kment Ferenc',
  'Molnár László',
  'Molnár Katalin',
  'Nagy Angie',
  'Sheila Vizi Virág',
  'Törzsök Ibolya',
];
---

<Base title="Segítőink" description="A Szent László Magyar Iskola önkéntes segítői.">
  <div class="container container--narrow prose">
    <h1 class="page-title">Segítőink</h1>

    <p>Segítőink a 2021/22-es tanévben:</p>

    <ul style="columns: 2; column-gap: 3rem;">
      {helpers.map((name) => <li>{name}</li>)}
    </ul>

    <p><strong>Nagyon szépen köszönjük segítőink önzetlen munkáját!</strong></p>
  </div>
</Base>
